# Optional public-policy fallback. Kept server-side so the front-end bundle does not expose it.
MUX_HERO_PLAYBACK_ID=

# Preferred signed-playback setup.
MUX_HERO_SIGNED_PLAYBACK_ID=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# Optional Mux playback restriction ID, such as a referrer restriction for the production domain.
MUX_PLAYBACK_RESTRICTION_ID=

# Optional, defaults to 900 seconds and is capped at 3600 seconds.
MUX_HERO_TOKEN_TTL_SECONDS=900
